<launch>

<rosparam file="$(find manipulator_motor_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="manipulator_motor" args="»Єјь 1_position_controller »Єјь 2_position_controller љљґујћіх 3_position_controller »Єјь 4_position_controller »Єјь 5_position_controller »Єјь 6_position_controller љљґујћіх 7_position_controller »Єјь 8_position_controller »Єјь 9_position_controller »Єјь 10_position_controller »Єјь 11_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/manipulator_motor/joint_states"/>
</node>

</launch>