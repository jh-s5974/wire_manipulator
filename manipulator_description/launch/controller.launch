<launch>

<rosparam file="$(find manipulator_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="manipulator" args="yaw1_position_controller br_position_controller fr_position_controller bl_position_controller fl_position_controller pitch1_position_controller pris1_position_controller pitch2_position_controller pitch3_position_controller pitch4_position_controller pitch5_position_controller pris2_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/manipulator/joint_states"/>
</node>

</launch>