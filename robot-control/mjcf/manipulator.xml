<?xml version="1.0" ?>
<mujoco model="manipulator">
    <!--
        와이어 매니퓰레이터 MuJoCo 모델
        URDF: manipulator_motor_description/urdf/manipulator_motor.urdf 기반

        조인트 → SDK 채널 매핑 (config/robotnl.yaml joints 순서와 일치):
          yaw1   → joint0  (base_yaw, revolute,  axis 0 0 1)
          pitch1 → joint1  (shoulder_pitch, revolute,  axis 1 0 0, range 0~π/2)
          pris1  → joint2  (lower_link_length, prismatic, axis 0 0 1, range 0~0.09m)
          pitch2 → joint3  (elbow_pitch, revolute,  axis 1 0 0, range 0~π/2)
          pris2  → joint4  (upper_link_length, prismatic, axis 0 0 1, range 0~0.09m)

        pitch3 : guide2_1 → upper_link1_1 passive 조인트
                 equality 제약으로 pitch2와 결합 (와이어 커플링 근사)

        fl/bl/fr/br : base_link 4륜 passive 조인트 (시각화 전용)
    -->

    <compiler angle="radian"
              meshdir="../../manipulator_motor_description/meshes"
              autolimits="true"/>

    <option gravity="0 0 -9.81" timestep="0.001"/>

    <default>
        <!-- armature: 감속기 반사 관성. frictionloss: 쿨롱 마찰. damping: 점성 감쇠 -->
        <joint frictionloss="0.1" armature="0.05" damping="1.0"/>
        <default class="revolute">
            <joint damping="2.0" armature="0.05"/>
        </default>
        <default class="prismatic">
            <joint damping="10.0" armature="0.01"/>
        </default>
        <default class="visual">
            <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.75 0.75 0.75 1"/>
        </default>
        <default class="collision">
            <geom group="3" contype="1" conaffinity="1"/>
        </default>
    </default>

    <asset>
        <mesh name="base_link"     file="base_link.stl"     scale="0.001 0.001 0.001"/>
        <mesh name="yaw_link_1"    file="yaw_link_1.stl"    scale="0.001 0.001 0.001"/>
        <mesh name="lower_link1_1" file="lower_link1_1.stl" scale="0.001 0.001 0.001"/>
        <mesh name="lower_link2_1" file="lower_link2_1.stl" scale="0.001 0.001 0.001"/>
        <mesh name="guide2_1"      file="guide2_1.stl"      scale="0.001 0.001 0.001"/>
        <mesh name="upper_link1_1" file="upper_link1_1.stl" scale="0.001 0.001 0.001"/>
        <mesh name="upper_link2_1" file="upper_link2_1.stl" scale="0.001 0.001 0.001"/>
        <mesh name="wheel_fl_1"    file="wheel_fl_1.stl"    scale="0.001 0.001 0.001"/>
        <mesh name="wheel_bl_1"    file="wheel_bl_1.stl"    scale="0.001 0.001 0.001"/>
        <mesh name="wheel_fr_1"    file="wheel_fr_1.stl"    scale="0.001 0.001 0.001"/>
        <mesh name="wheel_br_1"    file="wheel_br_1.stl"    scale="0.001 0.001 0.001"/>

        <texture type="skybox" builtin="gradient"
                 rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge"
                 rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
                 markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane"
                  texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="0 0 0.05" type="plane"
              material="groundplane" friction="1.0 0.005 0.0001"/>

        <!-- ═══════════════════════════════════════════════════
             base_link: 세계에 고정 (freejoint 없음)
             ═══════════════════════════════════════════════════ -->
        <body name="base_link" pos="0 0 0.3" quat="1 0 0 0">
            <geom type="mesh" mesh="base_link" class="visual"/>
            <inertial pos="7.545697705159546e-06 -6.288383922219511e-06 0.03594594111046938"
                      mass="0.8918760892092862"
                      fullinertia="0.013044 0.008436 0.020962 0.0 0.0 -1e-06"/>

            <!-- ── joint0: yaw1 (revolute, axis 0 0 1) ── -->
            <!-- URDF joint origin: 0 0 0.0566 rel to base_link -->
            <body name="yaw_link_1" pos="0 0 0.0566">
                <joint name="yaw1" type="hinge" pos="0 0 0"
                       axis="0 0 1" range="-2.094395 2.094395" class="revolute"/>
                <geom type="mesh" mesh="yaw_link_1" class="visual" pos="0 0 -0.0566"/>
                <inertial pos="0.02505185068167164 0.00017308161549442616 0.04350757657338304"
                          mass="0.9994851144783486"
                          fullinertia="0.005871 0.004947 0.008392 -9e-06 -0.000648 -5e-06"/>

                <!-- ── joint1: pitch1 (revolute, axis 1 0 0, range 0~π/2) ── -->
                <!-- URDF joint origin: 0.054 0.0005 0.0965 rel to yaw_link_1 -->
                <body name="lower_link1_1" pos="0.054 0.0005 0.0965">
                    <joint name="pitch1" type="hinge" pos="0 0 0"
                           axis="1 0 0" range="0.0 1.570796" class="revolute" damping="5.0"/>
                    <geom type="mesh" mesh="lower_link1_1" class="visual" pos="-0.054 -0.0005 -0.1531"/>
                    <inertial pos="-0.045625724622633944 3.860031882735413e-05 0.05414663144303672"
                              mass="0.42602249031214784"
                              fullinertia="0.002224 0.002372 0.000454 0.0 -7e-06 -1e-06"/>

                    <!-- ── joint2: pris1 (prismatic, axis 0 0 1) ── -->
                    <!-- URDF joint origin: -0.0482 5.7e-05 0.04 rel to lower_link1_1 -->
                    <body name="lower_link2_1" pos="-0.0482 5.7e-05 0.04">
                        <joint name="pris1" type="slide" pos="0 0 0"
                               axis="0 0 1" range="0.0 0.09" class="prismatic"/>
                        <geom type="mesh" mesh="lower_link2_1" class="visual"
                              pos="-0.0058 -0.000557 -0.1931"/>
                        <inertial pos="-0.00012108099532818183 4.2996702874214024e-05 0.16604608820037914"
                                  mass="0.48373366369507653"
                                  fullinertia="0.002598 0.002446 0.000395 1e-06 -3e-06 -1e-06"/>

                        <!-- ── joint3: pitch2 (revolute, axis 1 0 0, range 0~π/2) ── -->
                        <!-- URDF joint origin: 0.0435 0.000297 0.205944 rel to lower_link2_1 -->
                        <body name="guide2_1" pos="0.0435 0.000297 0.205944">
                            <joint name="pitch2" type="hinge" pos="0 0 0"
                                   axis="1 0 0" range="0.0 1.570796" class="revolute"/>
                            <geom type="mesh" mesh="guide2_1" class="visual"
                                  pos="-0.0493 -0.000854 -0.399044"/>
                            <inertial pos="0.004660145389821631 -8.351629404252335e-05 0.051805846663189714"
                                      mass="0.04577799695273184"
                                      fullinertia="6.9e-05 7e-05 5e-06 0.0 0.0 0.0"/>

                            <!-- pitch3: passive (guide2_1 → upper_link1_1)
                                 equality 제약으로 pitch2 값을 따름 (와이어 커플링 근사)
                                 URDF joint origin: -0.00255 0.00036 0.093499 rel to guide2_1 -->
                            <body name="upper_link1_1" pos="-0.00255 0.00036 0.093499">
                                <joint name="pitch3" type="hinge" pos="0 0 0"
                                       axis="1 0 0" range="0.0 1.570796" class="revolute"/>
                                <geom type="mesh" mesh="upper_link1_1" class="visual"
                                      pos="-0.04675 -0.001214 -0.492543"/>
                                <inertial pos="-0.030636725348820667 -0.00013414945634581928 0.09528109292485926"
                                          mass="0.7296264074388947"
                                          fullinertia="0.00632 0.006514 0.000624 -1e-06 -0.000515 -1.4e-05"/>

                                <!-- ── joint4: pris2 (prismatic, axis 0 0 1) ── -->
                                <!-- URDF joint origin: -0.00255 0.000491 0.102116 rel to upper_link1_1 -->
                                <body name="upper_link2_1" pos="-0.00255 0.000491 0.102116">
                                    <joint name="pris2" type="slide" pos="0 0 0"
                                           axis="0 0 1" range="0.0 0.09" class="prismatic"/>
                                    <geom type="mesh" mesh="upper_link2_1" class="visual"
                                          pos="-0.0442 -0.001705 -0.594659"/>
                                    <inertial pos="-0.012947590284332407 5.5232631865337074e-05 0.13361930444452141"
                                              mass="0.35479896787269694"
                                              fullinertia="0.001653 0.001635 0.000368 0.0 2.8e-05 -1.1e-05"/>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>

            <!-- ── 4륜 passive (시각화 전용, 비액추에이티드) ── -->
            <!-- URDF fl joint origin: 0.1452 -0.1552 0.0091 rel to base_link -->
            <body name="wheel_fl_1" pos="0.1452 -0.1552 0.0091">
                <joint name="fl" type="hinge" axis="1 0 0"/>
                <geom type="mesh" mesh="wheel_fl_1" class="visual" pos="-0.1452 0.1552 -0.0091"/>
                <inertial pos="0.022733132020722774 5.291380714977922e-07 -7.023490456061279e-06"
                          mass="0.05353335397371693"
                          fullinertia="2.5e-05 1.8e-05 1.8e-05 0.0 0.0 0.0"/>
            </body>

            <!-- URDF bl joint origin: 0.1452 0.1552 0.0091 rel to base_link -->
            <body name="wheel_bl_1" pos="0.1452 0.1552 0.0091">
                <joint name="bl" type="hinge" axis="1 0 0"/>
                <geom type="mesh" mesh="wheel_bl_1" class="visual" pos="-0.1452 -0.1552 -0.0091"/>
                <inertial pos="0.02273313202167407 5.110640206307249e-07 -7.024835080346459e-06"
                          mass="0.05353335397547339"
                          fullinertia="2.5e-05 1.8e-05 1.8e-05 0.0 0.0 0.0"/>
            </body>

            <!-- URDF fr joint origin: -0.1452 -0.1552 0.0091 rel to base_link -->
            <body name="wheel_fr_1" pos="-0.1452 -0.1552 0.0091">
                <joint name="fr" type="hinge" axis="1 0 0"/>
                <geom type="mesh" mesh="wheel_fr_1" class="visual" pos="0.1452 0.1552 -0.0091"/>
                <inertial pos="-0.022733132410434842 2.849096295387543e-06 6.441422285792531e-06"
                          mass="0.05353335889121502"
                          fullinertia="2.5e-05 1.8e-05 1.8e-05 0.0 0.0 0.0"/>
            </body>

            <!-- URDF br joint origin: -0.1452 0.1552 0.0091 rel to base_link -->
            <body name="wheel_br_1" pos="-0.1452 0.1552 0.0091">
                <joint name="br" type="hinge" axis="1 0 0"/>
                <geom type="mesh" mesh="wheel_br_1" class="visual" pos="0.1452 -0.1552 -0.0091"/>
                <inertial pos="-0.022733131995852668 4.4508618859961935e-06 5.458912178934669e-06"
                          mass="0.05353335383710403"
                          fullinertia="2.5e-05 1.8e-05 1.8e-05 0.0 0.0 0.0"/>
            </body>
        </body>
    </worldbody>

    <!-- 와이어 커플링: pitch3 = pitch2 (같은 축 방향, 동일 회전) -->
    <equality>
        <joint joint1="pitch3" joint2="pitch2" polycoef="0 1 0 0 0"/>
    </equality>

    <!-- 5개 제어 액추에이터 (pitch3, fl/bl/fr/br는 passive) -->
    <actuator>
        <motor name="act_yaw1"   joint="yaw1"   forcerange="-100 100" gear="1"/>
        <motor name="act_pitch1" joint="pitch1" forcerange="-100 100" gear="1"/>
        <motor name="act_pris1"  joint="pris1"  forcerange="-500 500" gear="1"/>
        <motor name="act_pitch2" joint="pitch2" forcerange="-100 100" gear="1"/>
        <motor name="act_pris2"  joint="pris2"  forcerange="-500 500" gear="1"/>
    </actuator>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <statistic center="0 0.1 0.3" extent="1.2"/>
</mujoco>
